# Nunca subas tu archivo real .env al repositorio.
# Usa este archivo como plantilla local.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Timezone por defecto del reporte
DEFAULT_TIMEZONE="America/Bogota"

# SMTP para envio de reportes por correo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="tu-password-o-app-password"
MAIL_FROM="tu-correo@gmail.com"
SMTP_TIMEOUT_SECONDS="10"
